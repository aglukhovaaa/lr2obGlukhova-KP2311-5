entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "pkg-config", "qhull", "tcl", "tk"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[[ports]]
localPort = 5904
externalPort = 80

[userenv]

[userenv.shared]
Anna_secret = "привет"
Sec_Glukhova_1 = "приветик :)"
Sec_Glukhova_2 = "возьми телефон деткааа"
Sec_Glukhova_3 = "я знаю ты хочешь позвонить"
